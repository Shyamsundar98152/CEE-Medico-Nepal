// Generate accordions groupings for Revision notes
function renderNoteAccordion(notes) {
  const targetElement = document.getElementById('notesAccordion');
  if (!targetElement) return;

  const entries = Object.entries(notes);
  if (!entries.length) {
    targetElement.innerHTML = `
      <div class="text-center py-10 text-slate-400">
        <i class="fas fa-folder-open text-3xl mb-2.5 block"></i> 
        <span class="text-xs font-semibold">No materials match your filter query.</span>
      </div>`;
    return;
  }

  // Group notes dynamically based on: Class -> Subject
  const grouped = {};
  entries.forEach(([id, note]) => {
    const cName = note.class || 'General Material';
    const sName = note.subject || 'Miscellaneous';
    if (!grouped[cName]) grouped[cName] = {};
    if (!grouped[cName][sName]) grouped[cName][sName] = [];
    grouped[cName][sName].push({ id, ...note });
  });

  let accordionHtml = '';
  for (const cName in grouped) {
    accordionHtml += `<div class="space-y-2">
      <h3 class="text-[10px] font-black tracking-wider text-slate-400 uppercase pt-2">${cName}</h3>`;
      
    for (const sName in grouped[cName]) {
      const classNotes = grouped[cName][sName];
      const iconClass = getSubjectIcon(sName);
      
      accordionHtml += `
        <div class="border border-slate-150 bg-slate-50/50 rounded-xl overflow-hidden shadow-sm">
          <button class="w-full flex items-center justify-between p-3.5 bg-white hover:bg-slate-50/50 text-left font-bold text-slate-800 text-xs custom-transition" onclick="toggleAccordion(this)">
            <span class="flex items-center gap-2.5">
              <span class="w-7 h-7 rounded-lg bg-slate-50 flex items-center justify-center border border-slate-100">
                <i class="fas ${iconClass}"></i>
              </span>
              <span>${sName} <span class="text-slate-400 font-medium text-[10px]">(${classNotes.length} files)</span></span>
            </span>
            <i class="fas fa-chevron-down text-[10px] text-slate-400 custom-transition"></i>
          </button>
          
          <div class="hidden p-3 bg-white border-t border-slate-100">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">`;
            
            classNotes.forEach(n => {
              accordionHtml += `
                <div class="p-3.5 rounded-xl border border-slate-150 hover:border-brand-300 bg-slate-50/30 flex flex-col gap-3 justify-between hover:shadow-md custom-transition">
                  <div class="space-y-1">
                    <h5 class="text-xs font-extrabold text-slate-800 line-clamp-2 leading-snug">${n.topic || 'Revision Note'}</h5>
                    <div class="flex items-center gap-1.5">
                      <span class="px-2 py-0.5 text-[9px] font-bold bg-slate-100 text-slate-500 rounded">${sName}</span>
                      <span class="text-[9px] font-semibold text-slate-400"><i class="fas fa-eye"></i> ${n.downloads || 0} hits</span>
                    </div>
                  </div>
                  <button class="w-full py-1.5 px-3 text-[10px] font-bold text-white bg-gradient-to-tr from-brand-600 to-indigo-500 hover:from-brand-700 hover:to-indigo-600 rounded-lg flex items-center justify-center gap-1.5 shadow-sm custom-transition" onclick="viewNote('${n.id}','${(n.topic || 'Study Note').replace(/'/g, "\\'")}', '${encodeURIComponent(n.pdfUrl || '')}')">
                    <i class="fas fa-book-open"></i> Read Study Materials
                  </button>
                </div>`;
            });
            
      accordionHtml += `
            </div>
          </div>
        </div>`;
    }
    accordionHtml += `</div>`;
  }
  
  targetElement.innerHTML = accordionHtml;
}

window.toggleAccordion = (btn) => {
  const content = btn.nextElementSibling;
  const chevron = btn.querySelector('.fa-chevron-down');
  
  if (content.classList.contains('hidden')) {
    content.classList.remove('hidden');
    if (chevron) chevron.classList.add('rotate-180');
  } else {
    content.classList.add('hidden');
    if (chevron) chevron.classList.remove('rotate-180');
  }
};

