                    <span class="text-[9px] font-semibold text-slate-400"><i class="fas fa-eye"></i> ${l.views || 0} views</span>
                  </div>
                </div>

              </div>
              
              <div class="p-3 pt-2 mt-3 border-t border-slate-50 flex items-center justify-between text-[10px] font-bold">
                <span class="text-red-600 flex items-center gap-1"><i class="fas fa-play-circle"></i> View Class</span>
