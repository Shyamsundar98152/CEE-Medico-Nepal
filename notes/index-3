// PDF dynamic viewer targeting the requested verbatim online_viewer_net.htm proxy
window.viewNote = async (id, title, encodedUrl) => {
  const url = decodeURIComponent(encodedUrl);
  let resolvedUrl = url;
  if (url.includes('drive.google.com')) {
    resolvedUrl = url.replace('/view', '/preview');
  }

  document.getElementById('viewerTitle').textContent = title;
  
  // Point verification frame directly to requested online_viewer_net.htm
  const viewerFrame = document.getElementById('viewerFrame');
  viewerFrame.src = `online_viewer_net.htm?url=${encodeURIComponent(resolvedUrl)}`;

  document.getElementById('pdfViewer').classList.remove('hidden');
  document.body.classList.add('overflow-hidden');

  try {
    const dbRef = ref(db, `notes/${id}`);
    const snapshot = await get(dbRef);
    if (snapshot.exists()) {
      update(dbRef, { downloads: (snapshot.val().downloads || 0) + 1 });
    }
  } catch (err) {
    console.warn("View Analytics Warning: ", err);
  }
};

window.closeViewer = () => {
  document.getElementById('pdfViewer').classList.add('hidden');
  document.getElementById('viewerFrame').src = '';
  document.body.classList.remove('overflow-hidden');
};

// YouTube Unrestricted Secure Embed Player Launcher
window.watchLecture = async (id, title, videoId, subject, duration) => {
  if (!videoId) {
    console.error("Lecture launching failed: missing YouTube Video ID.");
    return;
  }

  /* 
     CRITICAL REVISION FOR FIXING ERROR 153 & CONFIGURATION BLOCKS:
     1. Uses the secure, privacy-friendly 'youtube-nocookie.com' domain.
     2. Retains standard autoplay configuration.
     3. Bypasses manual raw postMessage speeds which caused Error 153 mismatched calls.
  */
  const cleanEmbedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1&controls=1`;
  const extYtUrl = `https://www.youtube.com/watch?v=${videoId}`;

  document.getElementById('playerTitle').textContent = title;
  document.getElementById('playerMeta').textContent = [subject, duration].filter(Boolean).join(' · ');
  document.getElementById('playerFrame').src = cleanEmbedUrl;
  
  const extBtn = document.getElementById('btnExternalYt');
  if (extBtn) extBtn.href = extYtUrl;

  document.getElementById('lecturePlayer').classList.remove('hidden');
  document.body.classList.add('overflow-hidden');

  try {
    const dbRef = ref(db, `lectures/${id}`);
    const snapshot = await get(dbRef);
    if (snapshot.exists()) {
      update(dbRef, { views: (snapshot.val().views || 0) + 1 });
    }
  } catch (err) {
    console.warn("Lecture Tracker Exception: ", err);
  }
};

window.closePlayer = () => {
  document.getElementById('lecturePlayer').classList.add('hidden');
  document.getElementById('playerFrame').src = '';
  document.body.classList.remove('overflow-hidden');
};

// Close modals via Keyboard Escape inputs
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeViewer();
    closePlayer();
  }
});
