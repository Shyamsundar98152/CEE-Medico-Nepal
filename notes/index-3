<script type="module">
import { initializeApp } from "firebase/app";
import { getDatabase, ref, get, update, onValue } from "firebase/database";

// Main Database Configuration
const firebaseConfig = {
  apiKey: "AIzaSyDfCO-xxHPpgSfE-I6KTmsw35Lo9n2v56s",
  authDomain: "live-quiz-6e77b.firebaseapp.com",
  databaseURL: "https://live-quiz-6e77b-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "live-quiz-6e77b",
  storageBucket: "live-quiz-6e77b.firebasestorage.app",
  messagingSenderId: "50057610341",
  appId: "1:50057610341:web:d4e88673a20757d4c9328c"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase(app);

let allNotes = {};
let allLectures = {};

// Responsive Mobile Drawer Navigation Handlers
const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('overlay');
const menuBtn = document.getElementById('menuBtn');

menuBtn.onclick = () => {
  sidebar.classList.toggle('-translate-x-full');
  overlay.classList.toggle('hidden');
};

overlay.onclick = () => {
  sidebar.classList.add('-translate-x-full');
  overlay.classList.add('hidden');
};

// UI Section Navigations Router
const sections = ['home', 'notes', 'lectures', 'mock'];
const pageTitles = { home: 'Dashboard Overview', notes: 'Revision Notes Library', lectures: 'Video Class Tutorials', mock: 'Mock Examinations' };

function navigate(targetSection) {
  sections.forEach(sec => {
    const pageEl = document.getElementById(`page-${sec}`);
    if (pageEl) {
      if (sec === targetSection) {
        pageEl.classList.remove('hidden');
      } else {
        pageEl.classList.add('hidden');
      }
    }
  });

  // Toggle CSS styling parameters on Nav Items
  document.querySelectorAll('.nav-item').forEach(btn => {
    if (btn.dataset.section === targetSection) {
      btn.classList.add('bg-white/10', 'text-white', 'border-r-4', 'border-brand-500');
      btn.classList.remove('text-slate-300');
    } else {
      btn.classList.remove('bg-white/10', 'text-white', 'border-r-4', 'border-brand-500');
      btn.classList.add('text-slate-300');
    }
  });

  document.getElementById('pageTitle').textContent = pageTitles[targetSection] || 'Dashboard Overview';
  
  // Clean up overlays on mobile viewport transitions
  sidebar.classList.add('-translate-x-full');
  overlay.classList.add('hidden');

  // Relocate viewport position upwards smoothly
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
window.navigate = navigate;

document.querySelectorAll('.nav-item').forEach(item => {
  item.onclick = () => navigate(item.dataset.section);
});

// Load real-time database listeners
listenDatabase();

function listenDatabase() {
  onValue(ref(db, 'notes'), snap => {
    allNotes = {};
    if (snap.exists()) snap.forEach(c => { allNotes[c.key] = c.val(); });
    updateHomeCounters(); 
    renderNoteAccordion(allNotes); 
    renderHomeRecent();
    buildDynamicFilters('noteFilterTabs', allNotes, selectedClass => {
      const filtered = selectedClass === 'all' ? allNotes : Object.fromEntries(Object.entries(allNotes).filter(([,n]) => n.class === selectedClass));
      renderNoteAccordion(filtered);
    });
  });

  onValue(ref(db, 'lectures'), snap => {
    allLectures = {};
    if (snap.exists()) snap.forEach(c => { allLectures[c.key] = c.val(); });
    updateHomeCounters(); 
    renderLecturesGrid(allLectures); 
    renderHomeLectures();
    buildDynamicFilters('lectureFilterTabs', allLectures, selectedClass => {
      const filtered = selectedClass === 'all' ? allLectures : Object.fromEntries(Object.entries(allLectures).filter(([,l]) => l.class === selectedClass));
      renderLecturesGrid(filtered);
    }, true);
  });
}

function updateHomeCounters() {
  const subjectsSet = new Set([
    ...Object.values(allNotes).map(n => n.subject),
    ...Object.values(allLectures).map(l => l.subject)
  ].filter(Boolean));

  document.getElementById('s-notes').textContent = Object.keys(allNotes).length;
  document.getElementById('s-lectures').textContent = Object.keys(allLectures).length;
  document.getElementById('s-subjects').textContent = subjectsSet.size;
}

// Build interactive search tabs categories
function buildDynamicFilters(tabContainerId, dataSet, onFilterSelection, useVideoTheme = false) {
  const uniqueClasses = ['all', ...new Set(Object.values(dataSet).map(item => item.class).filter(Boolean))];
  const container = document.getElementById(tabContainerId);
  if (!container) return;
  container.innerHTML = '';

  uniqueClasses.forEach((cls, idx) => {
    const filterBtn = document.createElement('button');
    filterBtn.dataset.class = cls;
    filterBtn.textContent = cls === 'all' ? 'All Materials' : cls;
    
    // Choose dynamic background highlights
    const activeClassStyles = useVideoTheme 
      ? 'bg-red-500 text-white' 
      : 'bg-brand-600 text-white';
    const inactiveClassStyles = 'bg-slate-100 text-slate-600 hover:bg-slate-200';

    filterBtn.className = `px-3 py-1.5 rounded-lg text-[10px] font-bold custom-transition ${idx === 0 ? activeClassStyles : inactiveClassStyles}`;

    filterBtn.addEventListener('click', () => {
      container.querySelectorAll('button').forEach(btn => {
        btn.className = `px-3 py-1.5 rounded-lg text-[10px] font-bold custom-transition ${inactiveClassStyles}`;
      });
      filterBtn.className = `px-3 py-1.5 rounded-lg text-[10px] font-bold custom-transition ${activeClassStyles}`;
      onFilterSelection(cls);
    });

    container.appendChild(filterBtn);
  });
}

