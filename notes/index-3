const subjectIcons = { 
  physics: 'fa-atom text-cyan-500', 
  chemistry: 'fa-flask text-teal-500', 
  biology: 'fa-dna text-emerald-500', 
  maths: 'fa-calculator text-indigo-500', 
  mathematics: 'fa-calculator text-indigo-500', 
  botany: 'fa-leaf text-green-500', 
  zoology: 'fa-paw text-amber-500', 
  english: 'fa-language text-purple-500' 
};

function getSubjectIcon(subject) {
  return subjectIcons[(subject || '').toLowerCase().trim()] || 'fa-file-medical text-brand-500';
